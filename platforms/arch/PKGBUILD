# Maintainer: Your Name <you@example.com>
pkgname=stremohub
pkgver=3.0
pkgrel=1
pkgdesc="Open-source media center — YouTube, streaming movies, IPTV live TV"
arch=('x86_64' 'aarch64')
url="https://github.com/YOUR_USERNAME/stremohub"
license=('MIT')
depends=('python' 'python-gobject' 'webkit2gtk' 'ffmpeg' 'yt-dlp')
optdepends=('python-pywebview: alternative launcher')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
  cd "${srcdir}/stremohub-${pkgver}"

  # Install app files
  install -dm755 "${pkgdir}/usr/lib/stremohub"
  cp -r src/app    "${pkgdir}/usr/lib/stremohub/"
  cp -r src/server "${pkgdir}/usr/lib/stremohub/"
  install -Dm755 "src/stremohub-gtk.py" "${pkgdir}/usr/lib/stremohub/stremohub-gtk.py"

  # Launcher binary
  install -dm755 "${pkgdir}/usr/bin"
  cat > "${pkgdir}/usr/bin/stremohub" << 'LAUNCHER'
#!/bin/bash
exec python3 /usr/lib/stremohub/stremohub-gtk.py "$@"
LAUNCHER
  chmod +x "${pkgdir}/usr/bin/stremohub"

  # Desktop entry
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/stremohub.desktop" << 'DESKTOP'
[Desktop Entry]
Name=StremoHub
Comment=Media center — YouTube, Movies, Live TV
Exec=stremohub
Icon=stremohub
Terminal=false
Type=Application
Categories=AudioVideo;Video;Player;
DESKTOP

  # License
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
